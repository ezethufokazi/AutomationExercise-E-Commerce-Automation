<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationExercise Master Suite">

    <listeners>
        <listener class-name="utilities.ExtentReportManager"/>
    </listeners>

    <!-- Uncomment to run specific groups only --> 
    <groups>
        <run>
            <!--<include name="Smoke"/>
            <include name="Regression"/>
            <include name="Sanity"/>
            <include name="Datadriven"/> -->
        </run>
    </groups>
    

    <test name="AutomationExercise Tests Grid-Linux">
    	<parameter name="os" value="linux"></parameter>
        <parameter name="browser" value="chrome"/>    

        <classes>
            <class name="testCases.TC001_SignupTest"/>
            <class name="testCases.TC002_LoginTest"/>
            <class name="testCases.TC003_LoginDataDrivenTest"/>
        </classes>
    </test>

</suite>
